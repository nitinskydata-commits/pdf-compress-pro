{
  "name": "pdf-compressor",
  "version": "1.0.0",
    "start": "node pdf-compressor/backend/app.js",
    "dev": "concurrently \"npm run backend\" \"npm run start:admin\"",
    "backend": "node pdf-compressor/backend/app.js",
    "build:admin": "cd admin-dashboard && npm install && npm run build && rimraf ../pdf-compressor/frontend/admin && mkdirp ../pdf-compressor/frontend/admin && cpx \"build/**/*\" ../pdf-compressor/frontend/admin/",
    "start:admin": "cd admin-dashboard && npm start"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-fileupload": "^1.4.0",
    "fs-extra": "^11.1.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.1",
    "live-server": "^1.2.2",
    "cpx": "^1.5.0",
    "mkdirp": "^3.0.1",
    "rimraf": "^5.0.1"
  }
}
