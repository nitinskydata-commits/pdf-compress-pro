{
  "name": "pdf-compressor",
  "version": "1.0.0",
  "scripts": {
    "start": "node pdf-compressor/backend/app.js",
    "dev": "concurrently \"npm run backend\" \"npm run start:admin\"",
    "backend": "node pdf-compressor/backend/app.js",
    "build:admin": "cd admin-dashboard && npm install && npm run build && npx rimraf ../pdf-compressor/frontend/admin && npx mkdirp ../pdf-compressor/frontend/admin && npx cpx \"build/**/*\" ../pdf-compressor/frontend/admin/",
    "start:admin": "cd admin-dashboard && npm start"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-fileupload": "^1.4.0",
    "express-rate-limit": "^6.10.0",
    "fs-extra": "^11.1.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "serverless-http": "^3.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.1",
    "live-server": "^1.2.2",
    "cpx": "^1.5.0",
    "mkdirp": "^3.0.1",
    "rimraf": "^5.0.1"
  }
}
